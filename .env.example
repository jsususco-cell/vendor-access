# ---- Quickbase connection (server-side only — never exposed to the browser) ----

# Your realm hostname, e.g. byrdson.quickbase.com  (the something.quickbase.com part of your URL)
QB_REALM=

# Quickbase user token. Keep this SECRET. In Vercel, set it as an Environment Variable,
# never commit it. Rotate the one that was shared in chat.
QB_USER_TOKEN=

# Table IDs (already known)
QB_TABLE_VENDORS=buskqh272
QB_TABLE_JOBS=buskqh3eh

# ---- Automated invite email (Gmail) ----
# The Google Workspace address that sends invites.
GMAIL_USER=admin@byrdsonservices.com
# A Google APP PASSWORD (16 chars, NOT the account password). Requires 2-Step
# Verification on the account. Generate at https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
# Shared secret the Code Page sends in the x-portal-key header. Must match the
# SEND_KEY value in the Code Page CONFIG. Keep it secret.
PORTAL_SEND_KEY=
# Public base URL of this app (used to build invite links inside emails).
PORTAL_BASE=https://vendor-access-lyart.vercel.app
